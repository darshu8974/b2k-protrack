# Normalize line endings: text files use LF in the repo, auto-converted on checkout.
* text=auto eol=lf

# Scripts and wrappers must stay LF even on Windows checkouts.
*.sh        text eol=lf
gradlew     text eol=lf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Treat known binaries as binary (no EOL conversion, no diff).
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.jar       binary
*.docx      binary
*.pptx      binary
*.woff      binary
*.woff2     binary
