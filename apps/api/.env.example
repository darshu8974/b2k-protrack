# Protrack API — environment template. Copy to a real .env (git-ignored) and fill in,
# or set these as OS/IDE environment variables. NEVER commit real credentials.

# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Use the JDBC form of your Neon connection string (note the "jdbc:" prefix and
# ?sslmode=require). Prefer the DIRECT connection (host WITHOUT "-pooler") so
# Flyway migrations work reliably.
DATABASE_URL=jdbc:postgresql://<your-neon-host>.neon.tech/<dbname>?sslmode=require
DATABASE_USERNAME=<your-neon-username>
DATABASE_PASSWORD=<your-neon-password>

# ── App secrets (defaults exist for dev; override in real environments) ───────
# PROTRACK_JWT_SECRET=<min-32-byte-random-secret>      # used from Sprint 1
# PROTRACK_AI_INTERNAL_KEY=dev-internal-key            # must match the AI service
# PROTRACK_AI_BASE_URL=http://localhost:8000
