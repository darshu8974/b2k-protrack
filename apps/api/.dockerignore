# Keep the build context small and reproducible: never ship build output, caches,
# secrets, or local runtime state into the image.
build/
.gradle/
*.log
hs_err_pid*

# Secrets / local env (only the .env.example template is tracked anyway).
.env
.env.*
!.env.example

# Local file-storage blobs created at runtime.
local-storage/

# Editor/OS noise.
.idea/
.vscode/
.DS_Store
