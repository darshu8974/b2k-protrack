# Protrack AI Service — environment template (copy to .env for local dev).
# All variables use the AI_ prefix (see app/core/config.py).

AI_ENVIRONMENT=local

# Shared secret authenticating Spring Boot -> FastAPI calls. Must match the API's
# PROTRACK_AI_INTERNAL_KEY. (HMAC upgrade is a future enhancement.)
AI_INTERNAL_KEY=dev-internal-key

# LLM provider abstraction.
# Default is the deterministic "mock" provider — the full pipeline runs with no API key.
# To use the real Claude API set AI_PROVIDER=claude and provide ANTHROPIC_API_KEY (nothing else).
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
AI_CLAUDE_MODEL=claude-sonnet-4-6
AI_LLM_MAX_TOKENS=4096
AI_LLM_TEMPERATURE=0.2

# Where to post progress callbacks (the Spring Boot api base URL)
AI_SPRING_CALLBACK_BASE_URL=http://localhost:8080
AI_REQUEST_TIMEOUT_MS=120000
