# Protrack AI service (FastAPI) — deployment environment reference.
# Copy into your platform's env settings (Render dashboard) or a local .env (git-ignored).
# NEVER commit real credentials. See also apps/ai/.env.example.

AI_ENVIRONMENT=prod

# Port to bind. Render injects PORT automatically; uvicorn reads ${PORT:-8000}.
# PORT=8000

# Shared secret authenticating Spring -> FastAPI; MUST match the API's PROTRACK_AI_INTERNAL_KEY.
AI_INTERNAL_KEY=<shared-internal-key>

# LLM provider. Default "mock" runs the full pipeline deterministically with no key.
# For real Claude: set AI_PROVIDER=claude and provide ANTHROPIC_API_KEY (nothing else changes).
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
AI_CLAUDE_MODEL=claude-sonnet-4-6
# AI_LLM_MAX_TOKENS=4096
# AI_LLM_TEMPERATURE=0.2

# Base URL of the Spring API, used for progress callbacks.
AI_SPRING_CALLBACK_BASE_URL=https://<your-api-service-url>
# AI_REQUEST_TIMEOUT_MS=120000
