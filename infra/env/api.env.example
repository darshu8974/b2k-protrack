# Protrack API (Spring Boot) — deployment environment reference.
# Copy the relevant keys into your platform's env settings (Render dashboard) or a local
# .env (git-ignored). NEVER commit real credentials. See also apps/api/.env.example.

# Active Spring profile: `local` or `prod`.
SPRING_PROFILES_ACTIVE=prod

# Port to bind. Render injects PORT automatically; Spring reads server.port=${PORT:8080}.
# PORT=8080

# ── Database (Neon PostgreSQL in prod; local Postgres in docker-compose) ──────────────
# JDBC form; use the DIRECT Neon host (no "-pooler") so Flyway migrations run reliably.
DATABASE_URL=jdbc:postgresql://<host>.neon.tech/<dbname>?sslmode=require
DATABASE_USERNAME=<username>
DATABASE_PASSWORD=<password>

# ── Secrets ───────────────────────────────────────────────────────────────────────────
# JWT signing secret, minimum 32 bytes. Generate a strong random value per environment.
PROTRACK_JWT_SECRET=<min-32-byte-random-secret>

# ── AI service wiring ─────────────────────────────────────────────────────────────────
PROTRACK_AI_BASE_URL=https://<your-ai-service-url>
# Shared secret; MUST match the AI service's AI_INTERNAL_KEY.
PROTRACK_AI_INTERNAL_KEY=<shared-internal-key>
# PROTRACK_AI_TIMEOUT_MS=120000
# PROTRACK_AI_RATE_LIMIT_RPM=30

# ── File storage (Phase 1: local disk; S3 later) ──────────────────────────────────────
PROTRACK_STORAGE_DRIVER=local
PROTRACK_STORAGE_LOCAL_PATH=/app/local-storage

# ── Email (Phase 1 default: log-only adapter, no SMTP needed) ─────────────────────────
PROTRACK_MAIL_ENABLED=false
# PROTRACK_MAIL_FROM=no-reply@protrack.app
# When PROTRACK_MAIL_ENABLED=true, also set the SMTP connection:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
