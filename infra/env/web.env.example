# Protrack web (React + Vite) — deployment environment reference.
# For local dev, copy to apps/web/.env.local (git-ignored). On Vercel, set this as a
# project environment variable. See also apps/web/.env.example.
#
# Only VITE_-prefixed vars are exposed to the browser bundle — never put secrets here.

# Base URL of the Spring API (WITHOUT the /api/v1 suffix).
#   local docker-compose / Vite dev : http://localhost:8080
#   production (Vercel)             : https://<your-api-service-url>
VITE_API_URL=https://<your-api-service-url>
