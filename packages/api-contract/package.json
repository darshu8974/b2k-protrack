{
  "name": "@protrack/api-contract",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Single source of truth for the Protrack HTTP contract: the OpenAPI document exported from the Spring API and the TypeScript types generated from it. CI runs `check` to fail on drift.",
  "main": "src/index.ts",
  "files": [
    "openapi.json",
    "src"
  ],
  "scripts": {
    "export": "node scripts/export-openapi.mjs",
    "generate": "node scripts/generate-types.mjs",
    "validate": "node scripts/validate-spec.mjs",
    "check": "node scripts/check-drift.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "openapi-typescript": "^7.9.1",
    "typescript": "^5.7.2"
  }
}
